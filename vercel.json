{
    "version": 2,
    "buildCommand": "cd my-cabinet && npm install && npm run build",
    "outputDirectory": "my-cabinet/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}